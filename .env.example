# ═══════════════════════════════════════════════
# LoveRush · 为爱冲锋 · 环境变量示例
# 复制此文件为 .env.local 并填入真实值
# 切勿提交 .env.local 到 git
# ═══════════════════════════════════════════════

# Runtime
NODE_ENV=development

# ──────────── Database ────────────
# Supabase PostgreSQL (Singapore region)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ──────────── Cache ────────────
# Upstash Redis
REDIS_URL=redis://default:PASSWORD@HOST:PORT
UPSTASH_REDIS_REST_URL=https://HOST.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ──────────── File Storage ────────────
# Cloudflare R2（D-102 · 留空走 stub）
# 1. Cloudflare Dashboard → R2 → Create Bucket "loverush-media"
# 2. R2 → Manage API Tokens → Create with Object Read & Write
# 3. 自定义域：R2 → Settings → 接入自定义域 media.loverush.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=loverush-media
R2_PUBLIC_URL=https://media.loverush.com

# ──────────── LLM Providers ────────────
# Claude (主)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (备 + ASR + Embedding)
OPENAI_API_KEY=sk-xxx

# Google Gemini (备)
GOOGLE_GEMINI_API_KEY=xxx

# ElevenLabs (TTS 声音复刻)
ELEVENLABS_API_KEY=xxx

# DeepL (翻译主)
DEEPL_API_KEY=xxx

# ──────────── Payment ────────────
# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Adyen (东南亚通道)
ADYEN_API_KEY=xxx
ADYEN_MERCHANT_ACCOUNT=xxx

# ──────────── Notification ────────────
# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+xxx

# Resend (Email)
RESEND_API_KEY=re_xxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_WEBHOOK_SECRET=xxx

# ──────────── Auth ────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN
JWT_ACCESS_TTL=30d
JWT_REFRESH_TTL=90d

# ──────────── Web Push ────────────
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@loverush.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ──────────── 真人核验 ────────────
# AWS Rekognition (Phase 2 POC)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-southeast-1

# ──────────── Monitoring ────────────
# Sentry（Phase 11.1 · 留空 noop · 4xx 不上报，仅 5xx）
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ──────────── Public (Next.js) ────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.loverush.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=
