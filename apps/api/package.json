{
  "name": "@loverush/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/zod-validator": "^0.4.0",
    "@loverush/db": "workspace:*",
    "@loverush/i18n": "workspace:*",
    "@loverush/llm": "workspace:*",
    "@loverush/types": "workspace:*",
    "@loverush/utils": "workspace:*",
    "@scure/bip39": "^1.4.0",
    "@sentry/node": "^8.55.2",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "drizzle-orm": "^0.34.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0",
    "stripe": "^17.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
